proc Reader {} {
    if { [gets stdin line] < 0} {
        fileevent stdin readable {}
        after idle "close stdin; set out 1"
    } else {
        if { [string range $line 0 4] == "lcd: " } {
            SetDisplay [string range $line 5 100]
        }
    }
}

