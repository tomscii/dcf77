proc DrawSeg { seg on } {
    global coords
    if { $on } {
        .lcdCanvas create polygon $coords($seg) -fill black -outline black
    } else {
        .lcdCanvas create polygon $coords($seg) -fill white -outline lightgrey
    }
}

